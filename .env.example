# ── Copy to .env for local runs. In CI these are GitHub Actions secrets. ──
# ── Put REAL values in .env (gitignored), NOT here. This file is committed. ──

# YouTube
YOUTUBE_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: path to a Netscape-format cookies file if YouTube throttles the runner.
YT_COOKIES_FILE=

# Cut detection
CUE_PHRASE=In preparation for today's message, we shall be reading from the book of
# 0.0–1.0; below this the episode is left as a draft instead of auto-publishing.
CONFIDENCE_THRESHOLD=0.7

# OpenAI (cut-point verification)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4-mini

# Transistor
TRANSISTOR_API_KEY=
TRANSISTOR_SHOW_ID=

# Cloudflare R2 archive (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Email alerts. Off by default — alerts print to the run log. Set EMAIL_ENABLED=true
# (plus the SMTP creds below, e.g. a Gmail app password) to also receive email.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ALERT_FROM=
ALERT_TO=eleonpilapil@gmail.com
